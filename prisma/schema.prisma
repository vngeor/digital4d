generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id               String                 @id @default(cuid())
  name             String?
  email            String                 @unique
  emailVerified    DateTime?
  image            String?
  role             Role                   @default(SUBSCRIBER)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  password         String?
  address          String?
  phone            String?
  birthDate        DateTime?
  city             String?
  country          String?
  accounts         Account[]
  auditLogs        AuditLog[]
  cartItems        CartItem[]
  createdContents  Content[]              @relation("ContentCreator")
  couponsCreated   Coupon[]               @relation("CouponCreator")
  mediaFiles       MediaFile[]
  notifications    Notification[]
  templatesCreated NotificationTemplate[] @relation("TemplateCreator")
  orders           Order[]
  createdProducts  Product[]              @relation("ProductCreator")
  sessions         Session[]
  permissions      UserPermission[]
  wishlistItems    WishlistItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  packageId String?
  quantity  Int      @default(1)
  data      Json     @default("{}")
  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, packageId])
}

model Order {
  id            String      @id @default(cuid())
  userId        String?
  customerName  String
  customerEmail String
  phone         String?
  description   String
  status        OrderStatus @default(PENDING)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderNumber   String      @unique @default("")
  user          User?       @relation(fields: [userId], references: [id])
}

model MenuItem {
  id         String    @id @default(cuid())
  slug       String    @unique
  titleBg    String
  titleEn    String
  titleEs    String
  order      Int       @default(0)
  published  Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  type       String    @default("general")
  bodyBg     String?
  bodyEn     String?
  bodyEs     String?
  showInNav  Boolean   @default(true)
  titleAlign String    @default("center")
  contents   Content[]

  @@index([published])
  @@index([order])
  @@index([type])
}

model ContentType {
  id        String   @id @default(cuid())
  slug      String   @unique
  nameBg    String
  nameEn    String
  nameEs    String
  color     String   @default("purple")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  descBg    String?
  descEn    String?
  descEs    String?

  @@index([order])
}

model Content {
  id          String    @id @default(cuid())
  type        String
  titleBg     String
  titleEn     String
  titleEs     String
  bodyBg      String?
  bodyEn      String?
  bodyEs      String?
  image       String?
  published   Boolean   @default(false)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  menuItemId  String?
  slug        String?   @unique
  createdById String?
  titleAlign  String    @default("center")
  createdBy   User?     @relation("ContentCreator", fields: [createdById], references: [id])
  menuItem    MenuItem? @relation(fields: [menuItemId], references: [id])

  @@index([type])
  @@index([published])
  @@index([menuItemId])
  @@index([createdById])
}

model Product {
  id                String           @id @default(cuid())
  slug              String           @unique
  sku               String?          @unique
  nameBg            String
  nameEn            String
  nameEs            String
  descBg            String?
  descEn            String?
  descEs            String?
  price             Decimal?         @db.Decimal(10, 2)
  salePrice         Decimal?         @db.Decimal(10, 2)
  onSale            Boolean          @default(false)
  currency          String           @default("EUR")
  priceType         String           @default("fixed")
  category          String
  tags              String[]
  image             String?
  gallery           String[]
  fileUrl           String?
  fileType          String?
  featured          Boolean          @default(false)
  published         Boolean          @default(false)
  order             Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  createdById       String?
  brandId           String?
  relatedProductIds String[]         @default([])
  status            String           @default("in_stock")
  bestSeller        Boolean          @default(false)
  upsellProductIds  String[]         @default([])
  bulkDiscountTiers String           @default("")
  brand             Brand?           @relation(fields: [brandId], references: [id])
  createdBy         User?            @relation("ProductCreator", fields: [createdById], references: [id])
  packages          ProductPackage[]
  variants          ProductVariant[]
  quotes            QuoteRequest[]
  wishlistItems     WishlistItem[]

  @@index([category])
  @@index([published])
  @@index([featured])
  @@index([order])
  @@index([brandId])
  @@index([createdById])
  @@index([createdAt])
}

model Brand {
  id         String    @id @default(cuid())
  slug       String    @unique
  nameBg     String
  nameEn     String
  nameEs     String
  image      String?
  order      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  descBg     String?
  descEn     String?
  descEs     String?
  titleAlign String    @default("left")
  products   Product[]

  @@index([order])
}

model Color {
  id        String           @id @default(cuid())
  nameBg    String
  nameEn    String
  nameEs    String
  hex       String
  order     Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  hex2      String?
  variants  ProductVariant[]

  @@index([order])
}

model Weight {
  id        String           @id @default(cuid())
  label     String           @unique
  grams     Int?
  order     Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  packages  ProductPackage[]

  @@index([order])
}

model ProductVariant {
  id              String                  @id @default(cuid())
  productId       String
  image           String?
  order           Int                     @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  status          String                  @default("in_stock")
  colorId         String
  packageVariants ProductPackageVariant[]
  color           Color                   @relation(fields: [colorId], references: [id])
  product         Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([colorId])
  @@index([order])
}

model ProductPackage {
  id              String                  @id @default(cuid())
  productId       String
  slug            String
  price           Decimal                 @db.Decimal(10, 2)
  salePrice       Decimal?                @db.Decimal(10, 2)
  sku             String?
  status            String                  @default("in_stock")
  order             Int                     @default(0)
  bulkDiscountTiers String                  @default("")
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  weightId          String
  product           Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  weight            Weight                  @relation(fields: [weightId], references: [id])
  packageVariants   ProductPackageVariant[]

  @@index([productId])
  @@index([weightId])
  @@index([order])
}

model ProductPackageVariant {
  id        String         @id @default(cuid())
  packageId String
  variantId String
  status    String         @default("in_stock")
  package   ProductPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([packageId, variantId])
  @@index([packageId])
  @@index([variantId])
}

model ProductCategory {
  id         String            @id @default(cuid())
  slug       String            @unique
  nameBg     String
  nameEn     String
  nameEs     String
  descBg     String?
  descEn     String?
  descEs     String?
  image      String?
  color      String            @default("emerald")
  order      Int               @default(0)
  parentId   String?
  title      String?
  titleAlign String            @default("left")
  parent     ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children   ProductCategory[] @relation("CategoryHierarchy")

  @@index([order])
  @@index([parentId])
}

model QuoteRequest {
  id           String         @id @default(cuid())
  productId    String?
  name         String
  email        String
  phone        String?
  message      String?
  fileName     String?
  fileUrl      String?
  fileSize     Int?
  status       String         @default("pending")
  quotedPrice  Decimal?       @db.Decimal(10, 2)
  adminNotes   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  userResponse String?
  quotedAt     DateTime?
  viewedAt     DateTime?
  quoteNumber  String         @unique @default("")
  messages     QuoteMessage[]
  product      Product?       @relation(fields: [productId], references: [id])

  @@index([status])
  @@index([email])
  @@index([productId])
}

model QuoteMessage {
  id          String       @id @default(cuid())
  quoteId     String
  senderType  String
  message     String
  quotedPrice Decimal?     @db.Decimal(10, 2)
  createdAt   DateTime     @default(now())
  quote       QuoteRequest @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model DigitalPurchase {
  id            String   @id @default(cuid())
  productId     String
  email         String
  downloadToken String   @unique
  downloadCount Int      @default(0)
  maxDownloads  Int      @default(3)
  expiresAt     DateTime
  stripeSession String?
  createdAt     DateTime @default(now())
  couponId      String?

  @@index([downloadToken])
  @@index([email])
  @@index([productId])
}

model Banner {
  id         String   @id @default(cuid())
  type       String
  titleBg    String
  titleEn    String
  titleEs    String
  subtitleBg String?
  subtitleEn String?
  subtitleEs String?
  image      String?
  link       String?
  linkTextBg String?
  linkTextEn String?
  linkTextEs String?
  published  Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([type, published])
  @@index([order])
}

model RolePermission {
  id       String  @id @default(cuid())
  role     Role
  resource String
  action   String
  allowed  Boolean @default(false)

  @@unique([role, resource, action])
  @@index([role])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  resource    String
  recordId    String
  recordTitle String?
  details     String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resource])
  @@index([action])
  @@index([createdAt])
}

model MediaFile {
  id           String   @id @default(cuid())
  url          String   @unique
  filename     String
  altBg        String?
  altEn        String?
  altEs        String?
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  uploadedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])

  @@index([uploadedById])
  @@index([mimeType])
  @@index([createdAt])
}

model UserPermission {
  id       String  @id @default(cuid())
  userId   String
  resource String
  action   String
  allowed  Boolean @default(false)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resource, action])
  @@index([userId])
}

model Coupon {
  id            String         @id @default(cuid())
  code          String         @unique
  type          String
  value         Decimal        @db.Decimal(10, 2)
  currency      String?
  minPurchase   Decimal?       @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int            @default(0)
  perUserLimit  Int            @default(1)
  productIds    String[]
  allowOnSale   Boolean        @default(false)
  active        Boolean        @default(true)
  startsAt      DateTime?
  expiresAt     DateTime?
  createdById   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  showOnProduct Boolean        @default(false)
  createdBy     User?          @relation("CouponCreator", fields: [createdById], references: [id])
  usages        CouponUsage[]
  notifications Notification[]

  @@index([code])
  @@index([active])
  @@index([createdById])
}

model CouponUsage {
  id             String   @id @default(cuid())
  couponId       String
  email          String
  originalPrice  Decimal  @db.Decimal(10, 2)
  discountAmount Decimal  @db.Decimal(10, 2)
  finalPrice     Decimal  @db.Decimal(10, 2)
  stripeSession  String?
  createdAt      DateTime @default(now())
  coupon         Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([email])
}

model Notification {
  id             String    @id @default(cuid())
  userId         String
  type           String
  title          String
  message        String
  link           String?
  couponId       String?
  quoteId        String?
  read           Boolean   @default(false)
  readAt         DateTime?
  createdById    String?
  createdAt      DateTime  @default(now())
  scheduledAt    DateTime?
  productId      String?
  reminderSentAt DateTime?
  coupon         Coupon?   @relation(fields: [couponId], references: [id])
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([type])
  @@index([scheduledAt])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model WishlistNotificationLog {
  id        String   @id @default(cuid())
  userId    String
  productId String
  type      String
  createdAt DateTime @default(now())

  @@index([userId, productId])
  @@index([createdAt])
}

model NotificationTemplate {
  id                String            @id @default(cuid())
  name              String
  trigger           String
  daysBefore        Int               @default(0)
  customMonth       Int?
  customDay         Int?
  recurring         Boolean           @default(true)
  titleBg           String
  titleEn           String
  titleEs           String
  messageBg         String
  messageEn         String
  messageEs         String
  link              String?
  couponEnabled     Boolean           @default(false)
  couponType        String?
  couponValue       Decimal?          @db.Decimal(10, 2)
  couponCurrency    String?
  couponDuration    Int?              @default(30)
  couponPerUser     Int               @default(1)
  couponProductIds  String[]
  couponAllowOnSale Boolean           @default(false)
  couponMinPurchase Decimal?          @db.Decimal(10, 2)
  active            Boolean           @default(true)
  lastRunAt         DateTime?
  lastRunCount      Int               @default(0)
  createdById       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  couponExpiresAt   DateTime?
  couponExpiryMode  String?           @default("duration")
  createdBy         User?             @relation("TemplateCreator", fields: [createdById], references: [id])
  sendLogs          TemplateSendLog[]

  @@index([trigger])
  @@index([active])
  @@index([createdById])
}

model TemplateSendLog {
  id         String               @id @default(cuid())
  templateId String
  userId     String
  year       Int
  couponId   String?
  createdAt  DateTime             @default(now())
  template   NotificationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, userId, year])
  @@index([templateId])
  @@index([userId])
}

model SiteSettings {
  id                     String   @id @default("singleton")
  freeShippingEnabled    Boolean  @default(false)
  freeShippingThreshold  Float?
  freeShippingCurrency   String   @default("EUR")
  updatedAt              DateTime @updatedAt
  globalUpsellProductIds String[]
  upsellOpenOnAdd        String   @default("upsell")
  upsellTabEnabled       Boolean  @default(true)
  welcomePopupCouponCode String   @default("")
  welcomePopupDelay      Int      @default(2)
  welcomePopupEnabled    Boolean  @default(false)
  welcomePopupImage      String   @default("")
  welcomePopupMessageBg  String   @default("")
  welcomePopupMessageEn  String   @default("")
  welcomePopupMessageEs  String   @default("")
  welcomePopupTitleBg    String   @default("")
  welcomePopupTitleEn    String   @default("")
  welcomePopupTitleEs    String   @default("")
  welcomePopupLink       String   @default("")
  bulkDiscountEnabled    Boolean  @default(false)
  bulkDiscountTiers      String   @default("[]")
}

enum Role {
  ADMIN
  EDITOR
  AUTHOR
  SUBSCRIBER
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
